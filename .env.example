# Tome library server — example env.
#
# For typical self-hosting, you can leave EVERY VARIABLE BELOW unset and
# just mount your books at LIBRARY_PATH (defaults to ./library). The
# server will pair to the public Tome hub (https://tome.arroyoautomation.com)
# the first time you visit /setup with a code from the iOS/Android app.

PORT=3000
NODE_ENV=production

# Where your books live (inside the container).
LIBRARY_PATH=/library

# Optional: the public URL the app uses to reach this server. Leave blank
# for LAN-only usage (the server will use the request's Host header).
# Set this if you're behind a tunnel (Cloudflare Tunnel, Tailscale, etc).
# PUBLIC_URL=https://tome.example.com

# Optional: override the Tome hub. Defaults to the public hub. Only set
# this if you're running your own hub (see "Running your own hub" in the
# README).
# HUB_URL=https://tome.arroyoautomation.com

# Origin allowlist for cross-origin requests. The mobile app does not
# need this — it talks to /files/:id directly via native HTTP. Leave as
# `*` unless you know you need to lock it down.
CORS_ORIGIN=*

# ---------------------------------------------------------------------
# Hub-mode only (advanced; ignore unless you're running your own hub)
# ---------------------------------------------------------------------
# IS_HUB=true
# SUPABASE_URL=https://<your-project>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<your service role key>
