# Server
PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Library
LIBRARY_PATH=/path/to/your/books

# CORS (optional — defaults to *, set to your client URL in production)
CORS_ORIGIN=http://localhost:3000

# Encryption key for media-server tokens at rest (Phase 1).
# Generate a random 32-byte hex string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this invalidates existing encrypted tokens — users will need to
# reconnect their Audiobookshelf / Calibre / etc. servers.
ENCRYPTION_KEY=
