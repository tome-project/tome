# Server
PORT=3000
NODE_ENV=development

# Postgres connection. For self-hosted Tome, point this at your local
# Postgres container (e.g. `postgresql://tome:tome@postgres:5432/tome`).
# For the Supabase-hosted DB, use the Session Pooler URL from
# Project Settings → Database → "Session pooler".
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tome

# Library
LIBRARY_PATH=/path/to/your/books

# CORS (optional — defaults to *, set to your client URL in production)
CORS_ORIGIN=http://localhost:3000

# Encryption key for media-server tokens at rest (Phase 1).
# Generate a random 32-byte hex string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this invalidates existing encrypted tokens — users will need to
# reconnect their Audiobookshelf / Calibre / etc. servers.
ENCRYPTION_KEY=

# Secret used to sign Tome-issued JWTs (access + refresh tokens). Must be at
# least 32 characters. Rotating invalidates every active session — users
# need to log in again. Generate with:
#   openssl rand -hex 32
JWT_SECRET=
